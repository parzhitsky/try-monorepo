{
  "name": "playground",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": null,
  "scripts": {
    "prestart": "touch src/index.ts",
    "start": "tsx src/index.ts",
    "clean": "rm -rf ./dist/*",
    "prebuild": "npm run clean",
    "// TODO:: remove npm run postbuild": "",
    "build": "tsc --project tsconfig.json; npm run postbuild",
    "postbuild": "tsc-alias -p tsconfig.json",
    "start:built": "node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "*",
    "tsc-alias": "1.8.8",
    "tsx": "4.2.0",
    "typescript": "5.3.2"
  }
}
